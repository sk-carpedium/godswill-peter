generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role           { admin member viewer client }
enum PostStatus     { draft scheduled publishing published failed archived pending_approval }
enum ScheduleType   { once recurring }
enum Recurrence     { daily weekly biweekly monthly }
enum AcctStatus     { active inactive disconnected }
enum AcctHealth     { healthy error disconnected pending }
enum Sentiment      { positive neutral negative }
enum MentionStatus  { new reviewed escalated resolved ignored dismissed }
enum Priority       { low medium high urgent }
enum TrendType      { hashtag topic event news viral_content }
enum Momentum       { rising peaked declining }
enum ReportFreq     { weekly monthly quarterly }
enum ReportStatus   { draft scheduled sent failed }
enum IntegType      { mailchimp sendgrid salesforce hubspot zapier slack shopify google_analytics }
enum SyncStatus     { healthy error pending never_synced }
enum CampaignStatus { draft active paused completed archived }
enum TaskStatus     { todo in_progress done blocked }
enum SubPlan        { free starter growth professional enterprise agency }
enum SubStatus      { active cancelled past_due trialing }
enum ApprovalStatus { pending_review approved rejected changes_requested withdrawn }
enum NotifType      { post_published post_failed mention crisis report_ready
                      approval_requested approval_approved approval_rejected
                      new_follower follower_milestone ecommerce_sale system }

// ALL 16 platforms — original 8 + 8 new from pages.config.js
enum Platform {
  instagram facebook twitter linkedin tiktok youtube pinterest twitch
  bluesky threads truthsocial rumble kick spotify google_business shopify
}

// ─── USERS & AUTH ─────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password_hash   String
  display_name    String?
  avatar_url      String?
  role            Role      @default(member)
  is_active       Boolean   @default(true)
  totp_secret            String?
  totp_enabled           Boolean   @default(false)
  last_login_at          DateTime?
  onboarding_completed   Boolean   @default(false)  // Onboarding.jsx auth.updateMe
  tour_completed         Boolean   @default(false)  // WelcomeChecklist + Layout updateMe
  checklist_dismissed    Boolean   @default(false)  // WelcomeChecklist updateMe
  checklist_completed    Boolean   @default(false)
  sidebar_order          Json?                       // SidebarCustomizer.jsx — ordered array of nav item names
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  workspace_members   WorkspaceMember[]
  refresh_tokens      RefreshToken[]
  notifications       Notification[]
  submitted_approvals ContentApproval[]  @relation("SubmittedBy")
  reviewed_approvals  ContentApproval[]  @relation("ReviewedBy")
}

model RefreshToken {
  id         String   @id @default(cuid())
  token      String   @unique
  user_id    String
  expires_at DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

// ─── WORKSPACES ───────────────────────────────────────────────────────────────

model Workspace {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  logo_url   String?
  website    String?
  industry   String?
  timezone   String   @default("UTC")
  is_active  Boolean  @default(true)
  // AgencyClientManagement.jsx filters Workspace.filter({ plan: 'agency' })
  plan       String?  @default("free")  // free|starter|growth|professional|agency — denormalized from Subscription for fast filtering
  // ClientPortal.jsx reads workspace.settings.custom_kpis + custom_dashboard_layout
  settings   Json?    // { custom_kpis: [], custom_dashboard_layout: [], white_label: {} }
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  members               WorkspaceMember[]
  brands                Brand[]
  social_accounts       SocialAccount[]
  posts                 Post[]
  campaigns             Campaign[]
  conversations         Conversation[]
  contacts              Contact[]
  media_assets          MediaAsset[]
  automations           Automation[]
  analytics             Analytics[]
  mentions              Mention[]
  keyword_tracks        KeywordTrack[]
  competitor_tracks     CompetitorTrack[]
  trend_analyses        TrendAnalysis[]
  team_tasks            TeamTask[]
  team_discussions      TeamDiscussion[]
  integrations          Integration[]
  client_reports        ClientReport[]
  content_templates     ContentTemplate[]
  brand_deals           BrandDeal[]
  revenues              Revenue[]
  saved_replies         SavedReply[]
  subscription          Subscription?
  notifications         Notification[]
  approval_workflows    ApprovalWorkflow[]
  content_approvals     ContentApproval[]
  agency_clients        AgencyClient[]        @relation("AgencyWorkspace")
  appearance_settings   AppearanceSettings?
  onboarding_state      OnboardingState?
  benchmarks            Benchmark[]
  ecommerce_integrations EcommerceIntegration[]
  support_tickets       SupportTicket[]
  custom_roles          CustomRole[]
  optimization_rules    OptimizationRule[]
  videos                Video[]
  platform_comments     PlatformComment[]
  user_invitations      UserInvitation[]
  platform_reviews      PlatformReview[]
  notification_schedules NotificationSchedule[]
}

model WorkspaceMember {
  id             String      @id @default(cuid())
  workspace_id   String
  user_id        String?     // null for invited-but-not-registered members
  user_email     String?     // email used for invitations (Team.jsx WorkspaceMember.create)
  role           Role        @default(member)
  custom_role_id String?
  status         String      @default("active") // active | invited | suspended
  joined_at      DateTime?
  is_active      Boolean     @default(true)
  permissions    Json?       // custom permissions object (RoleManagement.jsx)
  workspace      Workspace   @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user           User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  custom_role    CustomRole? @relation(fields: [custom_role_id], references: [id])
  @@unique([workspace_id, user_id])
  @@unique([workspace_id, user_email])
}

model Brand {
  id           String    @id @default(cuid())
  workspace_id String
  name         String
  logo_url     String?
  website      String?
  industry     String?
  description  String?
  brand_color  String?
  status       String?   @default("active")  // active|inactive
  is_active    Boolean   @default(true)
  // ComplianceChecker.jsx reads: brand_voice.tone, personality_traits, formality, banned_words, emoji_usage
  // BrandVoiceTrainer.jsx writes: brand_voice.{ tone, personality_traits, banned_words, preferred_hashtags, emoji_usage, formality, sample_posts, ai_profile }
  brand_voice       Json?  // { tone[], personality_traits[], formality, emoji_usage, banned_words[], preferred_hashtags[], sample_posts[], ai_profile{} }
  // ComplianceChecker.jsx reads: compliance_rules.require_disclosure, prohibited_content[]
  compliance_rules  Json?  // { require_disclosure: bool, prohibited_content: string[], ftc_required: bool, platform_policies: {} }
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  workspace       Workspace       @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  social_accounts SocialAccount[]
  mentions        Mention[]
  brand_deals     BrandDeal[]
}

// ─── SOCIAL ACCOUNTS ──────────────────────────────────────────────────────────

model SocialAccount {
  id                  String     @id @default(cuid())
  workspace_id        String
  brand_id            String?
  platform            Platform
  account_name        String
  account_handle      String?
  platform_account_id String?
  profile_image_url   String?
  access_token        String?    // AES-256-GCM encrypted
  refresh_token       String?    // AES-256-GCM encrypted
  token_expires_at    DateTime?
  follower_count      Int        @default(0)
  follower_growth     Float?    // % change from previous sync — set by cron
  follower_count_prev Int?      // previous count for growth calculation
  following_count     Int        @default(0)
  post_count          Int        @default(0)
  status              AcctStatus @default(active)
  health_status       AcctHealth @default(healthy)
  health_message      String?
  last_synced_at      DateTime?
  extra_data          Json?      // platform-specific (shop URL, artist ID, etc.)
  created_at          DateTime   @default(now())
  updated_at          DateTime   @updatedAt
  workspace      Workspace       @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  brand          Brand?          @relation(fields: [brand_id], references: [id])
  analytics      Analytics[]
  post_platforms PostPlatform[]
  @@unique([workspace_id, platform, platform_account_id])
}

// ─── POSTS ────────────────────────────────────────────────────────────────────

model Post {
  id                  String        @id @default(cuid())
  workspace_id        String
  campaign_id         String?
  title               String?
  status              PostStatus    @default(draft)
  // BulkActions.jsx: post.labels[], add_label action pushes to this array
  labels              String[]      @default([])
  // BulkActions.jsx: post.schedule = { type, scheduled_at } — already have scheduled_at, add schedule Json alias
  schedule            Json?         // { type: 'now'|'scheduled'|'recurring', scheduled_at, recurrence_rule, end_date } PostComposer shape
  post_type           String?
  content             Json?         // { text, hashtags, mentions, link }
  media_urls          String[]      @default([])
  schedule_type       ScheduleType?
  scheduled_at        DateTime?
  recurrence_rule     Recurrence?
  recurrence_end_date DateTime?
  parent_post_id      String?
  tags                String[]      @default([])
  notes               String?
  created_by          String?
  approval_required   Boolean       @default(false)
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt
  workspace    Workspace         @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  campaign     Campaign?         @relation(fields: [campaign_id], references: [id])
  platforms    PostPlatform[]
  analytics    Analytics[]
  revenues     Revenue[]
  approvals    ContentApproval[]
  parent_post  Post?             @relation("PostRecurrence", fields: [parent_post_id], references: [id])
  child_posts  Post[]            @relation("PostRecurrence")
  // TopPosts.jsx: post.engagement_rate, post.metrics.{likes,comments,shares,reach}
  published_at        DateTime?
  engagement_rate     Float?
  metrics             Json?       // { likes, comments, shares, saves, reach, impressions, clicks }
  thumbnail_url       String?     // video/image thumbnail for display
  ai_analysis         Json?       // { engagement_prediction, optimal_post_time, compliance_score, suggestions[] }
  is_sponsored        Boolean     @default(false)
  @@index([workspace_id, status])
  @@index([workspace_id, scheduled_at])
}

model PostPlatform {
  id                String     @id @default(cuid())
  post_id           String
  social_account_id String
  platform          Platform
  status            PostStatus @default(draft)
  platform_post_id  String?
  published_at      DateTime?
  error_message     String?
  likes             Int        @default(0)
  comments          Int        @default(0)
  shares            Int        @default(0)
  reach             Int        @default(0)
  impressions       Int        @default(0)
  post           Post          @relation(fields: [post_id], references: [id], onDelete: Cascade)
  social_account SocialAccount @relation(fields: [social_account_id], references: [id])
  @@unique([post_id, social_account_id])
}

// ─── CAMPAIGNS ────────────────────────────────────────────────────────────────

model Campaign {
  id              String         @id @default(cuid())
  workspace_id    String
  brand_id        String?        // CampaignBuilder.jsx sends brand_id
  name            String
  description     String?
  objective       String?        // awareness|engagement|conversion|retention|traffic
  status          CampaignStatus @default(draft)
  start_date      DateTime?
  end_date        DateTime?
  budget          Json?          // { total, spent, currency } or plain string from builder
  duration        String?        // e.g. "30 days" — raw string from CampaignBuilder
  platforms       String[]       @default([])  // platform slugs selected in builder
  goals           Json?
  // CampaignBuilder step 4: KPI targets
  kpis            Json?          // { target_reach, target_engagement, target_clicks, target_conversions, target_revenue }
  // CampaignBuilder step 5: UTM tracking
  utm_parameters  Json?          // { source, medium, campaign }
  tags            String[]       @default([])
  // CampaignPerformanceDashboard.jsx reads campaign.performance
  // Aggregated from Analytics rows linked to this campaign's posts
  performance     Json?          // { total_reach, total_engagement, total_clicks, total_conversions, total_revenue, total_posts, published_posts, engagement_rate }
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt
  workspace       Workspace      @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  posts           Post[]
  @@index([workspace_id, status])
  @@index([workspace_id, brand_id])
}

// ─── ANALYTICS ────────────────────────────────────────────────────────────────

model Analytics {
  id                     String    @id @default(cuid())
  workspace_id           String
  social_account_id      String?
  post_id                String?
  platform               Platform?
  date                   String
  period                 String    @default("daily")
  impressions            Int       @default(0)
  reach                  Int       @default(0)
  engagement             Int       @default(0)
  likes                  Int       @default(0)
  comments               Int       @default(0)
  shares                 Int       @default(0)
  saves                  Int       @default(0)
  clicks                 Int       @default(0)
  video_views            Int       @default(0)
  profile_visits         Int       @default(0)
  website_clicks         Int       @default(0)
  conversions            Int       @default(0)
  total_followers        Int       @default(0)
  new_followers          Int       @default(0)
  unfollowers            Int       @default(0)
  engagement_rate        Float     @default(0)
  follower_quality_score Int       @default(0)
  audience               Json?
  created_at             DateTime  @default(now())
  workspace      Workspace       @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  social_account SocialAccount?  @relation(fields: [social_account_id], references: [id])
  post           Post?           @relation(fields: [post_id], references: [id])
  @@index([workspace_id, date])
  @@index([social_account_id, date])
}

// ─── CONTACTS & CONVERSATIONS ─────────────────────────────────────────────────

model Contact {
  id               String    @id @default(cuid())
  workspace_id     String
  display_name     String?
  email            String?
  phone            String?
  platform         Platform?
  platform_user_id String?
  username         String?
  follower_count   Int       @default(0)
  follower_growth     Float?    // % change from previous sync — set by cron
  follower_count_prev Int?      // previous count for growth calculation
  is_influencer    Boolean   @default(false)
  tags             String[]  @default([])
  notes            String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  workspace       Workspace       @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  conversations   Conversation[]
  support_tickets SupportTicket[]
}

model Conversation {
  id              String    @id @default(cuid())
  workspace_id    String
  platform        Platform?
  contact_id      String?
  subject         String?
  status          String    @default("new")    // new | open | closed | snoozed
  // ConversationList.jsx: type = dm | comment | mention | reply
  type            String?   @default("dm")
  // ConversationList.jsx: participant Json { display_name, username, is_verified, profile_image_url }
  participant     Json?
  // ConversationList.jsx: priority = normal | high | urgent
  priority        String?   @default("normal")
  // ConversationList.jsx: is_vip shows gold star badge
  is_vip          Boolean   @default(false)
  // ConversationList.jsx: unread_count shows gold badge number
  unread_count    Int       @default(0)
  // ConversationList.jsx: sentiment = positive | neutral | negative
  sentiment       String?
  last_message_at DateTime?
  messages        Json[]    @default([])  // [{ content, role, timestamp, ... }]
  tags            String[]  @default([])
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  contact   Contact?  @relation(fields: [contact_id], references: [id])
  @@index([workspace_id, status])
  @@index([workspace_id, priority])
  @@index([workspace_id, type])
}

// ─── MEDIA ────────────────────────────────────────────────────────────────────

model MediaAsset {
  id            String   @id @default(cuid())
  workspace_id  String
  name          String
  // file_url is canonical — 'url' field added as alias for MediaLibraryPicker.jsx (asset.url)
  file_url      String
  url           String?  // alias of file_url — MediaLibraryPicker reads asset.url
  thumbnail_url String?
  file_type     String   @default("image")
  // MediaLibraryPicker uses asset.type = 'image'|'video'|'document' (vs file_type)
  type          String?  // image | video | document — MediaLibraryPicker.jsx
  mime_type     String?
  file_size     Int      @default(0)
  width         Int?
  height        Int?
  duration      Float?
  alt_text      String?
  tags          String[] @default([])
  // MediaLibraryPicker: product|lifestyle|promotional|event|team|brand_asset|social_media|other
  category      String?
  // MediaLibraryPicker shows Brand Assets section when is_brand_asset = true (gold star badge)
  is_brand_asset Boolean @default(false)
  created_at    DateTime @default(now())
  workspace     Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  @@index([workspace_id, category])
  @@index([workspace_id, is_brand_asset])
}

// ─── SOCIAL LISTENING ─────────────────────────────────────────────────────────

model Mention {
  id              String        @id @default(cuid())
  workspace_id    String
  brand_id        String?
  platform        Platform?
  mention_type    String        @default("brand_keyword")
  author          Json
  content         String
  url             String        @default("")
  sentiment       Sentiment     @default(neutral)
  sentiment_score Float         @default(0)
  engagement      Json?
  influence_score Float         @default(0)
  topics          String[]      @default([])
  keywords        String[]      @default([])
  is_crisis       Boolean       @default(false)
  priority        Priority      @default(medium)
  status          MentionStatus @default(new)
  mentioned_at    DateTime      @default(now())
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  brand     Brand?    @relation(fields: [brand_id], references: [id])
  @@index([workspace_id, status])
  @@index([workspace_id, is_crisis])
}

model KeywordTrack {
  id           String   @id @default(cuid())
  workspace_id String
  brand_id     String?
  keyword      String
  is_active    Boolean  @default(true)
  stats        Json?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  @@unique([workspace_id, keyword])
}

model CompetitorTrack {
  id                String   @id @default(cuid())
  workspace_id      String
  competitor_name   String
  website           String?
  social_handles    Json?
  tracking_keywords String[] @default([])
  metrics           Json?
  recent_campaigns  Json[]   @default([])
  strengths         String[] @default([])
  weaknesses        String[] @default([])
  last_analyzed_at  DateTime?
  is_active         Boolean  @default(true)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  workspace         Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
}

model TrendAnalysis {
  id                  String    @id @default(cuid())
  workspace_id        String
  trend_title         String
  trend_type          TrendType
  keywords            String[]  @default([])
  platforms           String[]  @default([])
  momentum            Momentum  @default(rising)
  velocity            Float     @default(0)
  total_mentions      Int       @default(0)
  total_reach         Int       @default(0)
  sentiment_breakdown Json?
  relevance_score     Float     @default(0)
  opportunity_score   Float     @default(0)
  ai_insights         String?
  recommended_action  String?
  detected_at         DateTime  @default(now())
  created_at          DateTime  @default(now())
  workspace           Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  @@index([workspace_id, detected_at])
}

// ─── TEAM ─────────────────────────────────────────────────────────────────────

model TeamTask {
  id           String     @id @default(cuid())
  workspace_id String
  title        String
  description  String?
  status       TaskStatus @default(todo)
  assigned_to  String?
  due_date     DateTime?
  priority     Priority   @default(medium)
  tags         String[]   @default([])
  created_by   String?
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt
  workspace    Workspace  @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  @@index([workspace_id, status])
}

model TeamDiscussion {
  id           String   @id @default(cuid())
  workspace_id String
  title        String
  body         String?
  author_id    String?
  replies      Json[]   @default([])
  is_pinned    Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
}

// ─── CONTENT TOOLS ────────────────────────────────────────────────────────────

model ContentTemplate {
  id           String    @id @default(cuid())
  workspace_id String
  name         String
  description  String?
  platform     Platform?
  post_type    String?
  content      Json
  tags         String[]  @default([])
  use_count    Int       @default(0)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
}

model SavedReply {
  id           String   @id @default(cuid())
  workspace_id String
  title        String
  content      String
  tags         String[] @default([])
  use_count    Int      @default(0)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
}

model Automation {
  id           String    @id @default(cuid())
  workspace_id String
  name         String
  description  String?
  // AutomationBuilder.jsx trigger shape:
  // { type: 'new_comment'|'new_mention'|'new_dm'|'new_follower'|'keyword_detected'|
  //          'sentiment_detected'|'scheduled'|'engagement_threshold'|'post_published',
  //   platforms: string[],
  //   conditions: [{ field, operator, value }] }
  trigger      Json
  // AutomationBuilder.jsx actions shape:
  // [{ type: 'auto_reply'|'ai_response'|'assign_team'|'add_label'|
  //          'send_notification'|'hide_content'|'escalate'|'webhook',
  //    config: {} }]
  actions      Json[]
  // AutomationBuilder.jsx status field
  status       String    @default("draft")  // draft | active | paused
  is_active    Boolean   @default(true)
  run_count    Int       @default(0)
  last_run_at  DateTime?
  error_count  Int       @default(0)
  last_error   String?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  @@index([workspace_id, status])
  @@index([workspace_id, is_active])
}

// ─── REVENUE & BRAND DEALS ────────────────────────────────────────────────────

model BrandDeal {
  id              String    @id @default(cuid())
  workspace_id    String
  brand_id        String?
  deal_name       String
  // ActiveDeals.jsx + DealPerformance.jsx use brand_name + brand_logo_url
  brand_name      String?
  brand_logo_url  String?
  sponsor_name    String?
  // ActiveDeals.jsx: deal_type = 'sponsored_post'|'affiliate'|'brand_ambassador'|'product_placement'
  deal_type       String?   @default("sponsored_post")
  amount          Float     @default(0)
  // DealPerformance: deal.contract_value
  contract_value  Float?
  currency        String    @default("USD")
  status          String    @default("pending") // pending|negotiating|active|completed|cancelled
  // ActiveDeals/DealPerformance: deliverables.posts_required/completed, stories_*, reels_*
  deliverables    Json?     // { posts_required, posts_completed, stories_required, stories_completed, reels_required, reels_completed }
  // DealPerformance: performance.revenue_generated, total_reach, total_engagement, total_clicks, total_conversions
  performance     Json?     // { revenue_generated, total_reach, total_engagement, total_clicks, total_conversions, total_posts, roi }
  // DealPerformance: payment_structure.type, base_amount, commission_rate
  payment_structure Json?   // { type: 'fixed'|'commission'|'hybrid', base_amount, commission_rate }
  // DealPerformance: kpis (targets)
  kpis            Json?     // { target_reach, target_engagement, target_conversions }
  start_date      DateTime?
  end_date        DateTime?
  contract_url    String?
  commission_rate Float?
  promo_code      String?
  tracking_url    String?
  notes           String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  brand     Brand?    @relation(fields: [brand_id], references: [id])
  revenues  Revenue[]
}

model Revenue {
  id            String    @id @default(cuid())
  workspace_id  String
  brand_deal_id String?
  post_id       String?
  source        String    // brand_deal, affiliate, ads, subscription, ecommerce, tips, merchandise
  amount        Float
  currency      String    @default("USD")
  description   String?
  platform      Platform?
  date          DateTime  @default(now())
  // ExportableEarnings.jsx uses r.transaction_date — alias of date
  transaction_date DateTime? // alias of date — populated on create if provided
  // UnifiedEngagementHub: r.source === 'product_sale' — add to allowed sources
  // All sources: brand_deal | affiliate | ads | subscription | ecommerce | tips | merchandise | product_sale | sponsored_post
  created_at    DateTime  @default(now())
  workspace  Workspace  @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  brand_deal BrandDeal? @relation(fields: [brand_deal_id], references: [id])
  post       Post?      @relation(fields: [post_id], references: [id])
  @@index([workspace_id, date])
  @@index([workspace_id, post_id])
  @@index([workspace_id, source])
}

// ─── INTEGRATIONS ─────────────────────────────────────────────────────────────

model Integration {
  id               String     @id @default(cuid())
  workspace_id     String
  name             String
  integration_type IntegType
  is_active        Boolean    @default(true)
  credentials      Json?
  settings         Json?
  sync_status      SyncStatus @default(never_synced)
  sync_error       String?
  last_synced_at   DateTime?
  stats            Json?
  created_at       DateTime   @default(now())
  updated_at       DateTime   @updatedAt
  workspace        Workspace  @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  @@unique([workspace_id, integration_type])
}

// ─── SUBSCRIPTIONS ────────────────────────────────────────────────────────────

model Subscription {
  id                     String    @id @default(cuid())
  workspace_id           String    @unique
  user_email             String?   // Pricing.jsx writes user.email here
  plan                   SubPlan   @default(free)
  plan_id                String    @default("free")  // "free"|"starter"|"growth"|"professional"|"agency"
  billing_cycle          String    @default("monthly") // monthly | yearly
  price                  String?   // display price e.g. "$49.99" (from Pricing.jsx)
  status                 SubStatus @default(trialing)
  stripe_customer_id     String?
  stripe_subscription_id String?
  current_period_start   DateTime?
  current_period_end     DateTime?
  trial_end              DateTime?
  trial_ends_at          DateTime? // alias used by Pricing.jsx
  seats                  Int       @default(1)
  // Usage limits per plan (from Pricing.jsx getUsageLimits)
  usage_limits           Json?     // { social_accounts, posts_per_month, team_members, ai_requests_per_month, storage_gb, brands, workspaces }
  // Real-time usage counters
  current_usage          Json?     // { social_accounts, posts_this_month, team_members, ai_requests_this_month, storage_used_gb }
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
  workspace              Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
}

// ─── REPORTS ──────────────────────────────────────────────────────────────────

model ClientReport {
  id                   String       @id @default(cuid())
  workspace_id         String
  // AutomatedReportDelivery.jsx filters by client_workspace_id + status
  client_workspace_id  String?
  report_name          String
  // AutomatedReportDelivery.jsx: performance|engagement|growth|comprehensive
  report_type          String?      @default("comprehensive")
  frequency            ReportFreq   @default(monthly)
  status               ReportStatus @default(active)
  date_range           Json?
  client_email         String?
  // AutomatedReportDelivery.jsx: personalized message at top of report
  custom_message       String?
  // AutomatedReportDelivery.jsx: KPI IDs ['reach','impressions','engagement','followers',...]
  metrics_included     String[]     @default([])
  // AutomatedReportDelivery.jsx: delivery timing
  delivery_time        String?      @default("09:00") // HH:MM UTC
  delivery_day         String?      @default("1")     // '1'-'7' weekly | '1','15','-1' monthly
  pdf_url              String?
  analytics_data       Json?
  white_label_settings Json?
  custom_sections      Json[]       @default([])
  auto_send_enabled    Boolean      @default(true)
  next_scheduled_send  DateTime?
  last_sent_at         DateTime?
  created_at           DateTime     @default(now())
  updated_at           DateTime     @updatedAt
  workspace            Workspace    @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  @@index([workspace_id, status])
  @@index([client_workspace_id, auto_send_enabled])
}

// ─── NOTIFICATIONS (LiveNotifications page) ───────────────────────────────────

model Notification {
  id           String    @id @default(cuid())
  workspace_id String
  user_id      String?
  type         NotifType
  title        String
  message      String
  data         Json?
  action_url   String?
  is_read      Boolean   @default(false)
  created_at   DateTime  @default(now())
  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user         User?     @relation(fields: [user_id], references: [id])
  @@index([workspace_id, is_read])
  @@index([workspace_id, created_at])
  @@index([user_id, is_read])
}

// ─── APPROVAL WORKFLOW (ApprovalWorkflow + WorkflowApprovals pages) ───────────

model ApprovalWorkflow {
  id           String   @id @default(cuid())
  workspace_id String
  name         String
  description  String?
  stages       Json[]   // [{ name, approver_ids, order, auto_approve_after_hours? }]
  platforms    String[] @default([])
  post_types   String[] @default([])
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  workspace    Workspace         @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  approvals    ContentApproval[]
}

model ContentApproval {
  id             String         @id @default(cuid())
  workspace_id   String
  workflow_id    String?
  post_id        String?
  status         ApprovalStatus @default(pending_review)
  current_stage  Int            @default(0)
  stage_history  Json[]         @default([])
  submitted_by   String?
  reviewed_by    String?
  review_notes   String?
  due_date       DateTime?
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  workspace Workspace        @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  workflow  ApprovalWorkflow? @relation(fields: [workflow_id], references: [id])
  post      Post?             @relation(fields: [post_id], references: [id])
  submitter User?             @relation("SubmittedBy", fields: [submitted_by], references: [id])
  reviewer  User?             @relation("ReviewedBy", fields: [reviewed_by], references: [id])
  @@index([workspace_id, status])
}

// ─── AGENCY CLIENT MANAGEMENT ─────────────────────────────────────────────────

model AgencyClient {
  id                  String    @id @default(cuid())
  agency_workspace_id String
  name                String
  email               String?
  company             String?
  status              String    @default("active")
  client_workspace_id String?
  plan                String?
  monthly_retainer    Float?
  currency            String    @default("USD")
  contract_start      DateTime?
  contract_end        DateTime?
  onboarding_complete Boolean   @default(false)
  tags                String[]  @default([])
  notes               String?
  contact_person      String?
  website             String?
  industry            String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  agency_workspace    Workspace @relation("AgencyWorkspace", fields: [agency_workspace_id], references: [id], onDelete: Cascade)
  @@index([agency_workspace_id, status])
}

// ─── APPEARANCE SETTINGS ──────────────────────────────────────────────────────

model AppearanceSettings {
  id            String   @id @default(cuid())
  workspace_id  String   @unique
  primary_color String   @default("#d4af37")
  font_size     String   @default("14px")
  sidebar_style String   @default("expanded")
  dark_mode     String   @default("system")
  logo_url      String?
  favicon_url   String?
  brand_name    String?
  custom_css    String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  workspace     Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
}

// ─── ONBOARDING STATE ─────────────────────────────────────────────────────────

model OnboardingState {
  id                  String   @id @default(cuid())
  workspace_id        String   @unique
  user_id             String
  current_step        Int      @default(0)
  completed_steps     Int[]    @default([])
  is_complete         Boolean  @default(false)
