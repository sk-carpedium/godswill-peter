}

// ─── BENCHMARKING ─────────────────────────────────────────────────────────────

model Benchmark {
  id            String    @id @default(cuid())
  workspace_id  String
  industry      String
  platform      Platform?
  metric_name   String
  metric_value  Float
  percentile_25 Float?
  percentile_50 Float?
  percentile_75 Float?
  top_10_pct    Float?
  your_value    Float?
