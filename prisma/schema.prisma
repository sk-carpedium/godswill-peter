// ─── ROLE MANAGEMENT ──────────────────────────────────────────────────────────

model CustomRole {
  id           String   @id @default(cuid())
  workspace_id String
  name         String
  description  String?
  permissions  Json
  is_default   Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  workspace    Workspace         @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  members      WorkspaceMember[]
  @@unique([workspace_id, name])
}

// ─── OPTIMIZATION RULES ───────────────────────────────────────────────────────

model OptimizationRule {
  id           String    @id @default(cuid())
  workspace_id String
  name         String
  description  String?
  rule_type    String
  platform     Platform?
  config       Json
  is_active    Boolean   @default(true)
  run_count    Int       @default(0)
  last_run_at  DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
}

// ─── APP LOGS (from NavigationTracker.jsx → base44.appLogs.logUserInApp) ──────
// Tracks every page navigation across all 61 pages. Called silently on each
// route change via: base44.appLogs.logUserInApp(pageName)

model AppLog {
  id           String   @id @default(cuid())
  user_id      String
  workspace_id String?
  page_name    String?
  event_type   String   @default("page_view")  // page_view | click | form_submit | error
  path         String?
  referrer     String?
  duration_ms  Int?
  metadata     Json?
  ip           String?
  user_agent   String?
  created_at   DateTime @default(now())

  @@index([user_id, created_at])
  @@index([workspace_id, page_name])
  @@index([event_type, created_at])
}

// ═══════════════════════════════════════════════════════════════════════════════
// ADDITIONS FROM 18-PAGE ANALYSIS
// ═══════════════════════════════════════════════════════════════════════════════

// ─── VIDEO ASSETS (YouTube / Twitch / Rumble / Kick pages) ───────────────────
// VideoUploader + VideoDownloader + CommentManager + NotificationCenter
// components all need a server-side video record

model Video {
  id                  String    @id @default(cuid())
  workspace_id        String
  social_account_id   String?
  platform            Platform
  title               String
  description         String?
  file_url            String?
  thumbnail_url       String?
  duration_seconds    Int?
  file_size_bytes     BigInt?
  status              String    @default("uploading") // uploading | processing | published | failed | downloading
  platform_video_id   String?   // ID once published to the platform
  platform_url        String?
  views               Int       @default(0)
  likes               Int       @default(0)
  comments_count      Int       @default(0)
  tags                String[]  @default([])
  metadata            Json?     // platform-specific extra fields
  published_at        DateTime?
  created_by          String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  workspace      Workspace       @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  comments       PlatformComment[]

  @@index([workspace_id, platform])
  @@index([workspace_id, status])
}

// ─── PLATFORM COMMENTS (Streaming + social platform comment managers) ─────────
// Backs: CommentManager (YouTube/Twitch/Rumble), CommentsManager (social pages)

model PlatformComment {
  id                  String    @id @default(cuid())
  workspace_id        String
  video_id            String?   // null for post comments
  social_account_id   String?
  platform            Platform
  platform_comment_id String?   // external ID from the platform
  author_name         String
  author_avatar       String?
  content             String
  likes               Int       @default(0)
  is_reply            Boolean   @default(false)
  parent_comment_id   String?
  status              String    @default("visible")  // visible | hidden | spam | reported
  sentiment           Sentiment @default(neutral)
  is_pinned           Boolean   @default(false)
  replied_at          DateTime?
  reply_content       String?
  commented_at        DateTime  @default(now())
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  workspace    Workspace  @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  video        Video?     @relation(fields: [video_id], references: [id])

  @@index([workspace_id, platform])
  @@index([video_id])
  @@index([status])
}

// ─── USER INVITATIONS (Team.jsx → base44.users.inviteUser) ───────────────────

model UserInvitation {
  id            String    @id @default(cuid())
  workspace_id  String
  invited_by    String    // user ID of inviter
  email         String
  role          Role      @default(member)
  token         String    @unique  // secure invite token
  status        String    @default("pending") // pending | accepted | expired | revoked
  expires_at    DateTime
  accepted_at   DateTime?
  created_at    DateTime  @default(now())

  @@index([email, status])
  @@index([workspace_id, status])
  @@unique([workspace_id, email])
}

// ─── PLATFORM REVIEWS (Facebook ReviewsManager + GoogleBusiness ReviewsManager) ─

model PlatformReview {
  id                  String    @id @default(cuid())
  workspace_id        String
  social_account_id   String?
  platform            Platform
  platform_review_id  String?   // external ID from platform
  reviewer_name       String
  reviewer_avatar     String?
  reviewer_id         String?
  rating              Int       @default(5)      // 1-5 stars
  title               String?
  content             String?
  sentiment           Sentiment @default(neutral)
  is_verified         Boolean   @default(false)
  is_featured         Boolean   @default(false)
  status              String    @default("visible")   // visible | hidden | reported | responded
  reply_content       String?
  replied_at          DateTime?
  helpful_count       Int       @default(0)
  photos              String[]  @default([])
  tags                String[]  @default([])
  reviewed_at         DateTime  @default(now())
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@index([workspace_id, platform])
  @@index([workspace_id, rating])
  @@index([workspace_id, status])
}

// ─── LIVE NOTIFICATION SCHEDULES (LiveNotifications page) ─────────────────────
// Auto-notify followers when posts/stories/reels/shorts/videos/livestreams go live

model NotificationSchedule {
  id                  String    @id @default(cuid())
  workspace_id        String
  post_id             String?
  social_account_id   String?
  platform            Platform?
  notification_type   String    // post | story | reel | short | video | livestream
  title               String
  message             String
  scheduled_at        DateTime?
  sent_at             DateTime?
  status              String    @default("pending") // pending | sent | failed | cancelled
  audience            String    @default("all_followers") // all_followers | subscribers | custom
  channels            String[]  @default([])  // push | email | sms
  metadata            Json?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@index([workspace_id, status])
  @@index([workspace_id, scheduled_at])
}

// ─── AI CONVERSATIONS (base44.agents.* — AIAssistant.jsx + CustomerSupport.jsx) ──
// Backs: agents.createConversation, addMessage, listConversations, subscribeToConversation

model AIConversation {
  id           String   @id @default(cuid())
  workspace_id String?
  user_id      String
  agent_name   String   @default("assistant") // assistant | customer_support | analytics
  title        String?
  messages     Json[]   @default([])  // [{ role:'user'|'assistant', content, timestamp, metadata? }]
  metadata     Json?    // { name, description, context, file_urls[] }
  is_active    Boolean  @default(true)
  token_count  Int      @default(0)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([user_id, agent_name])
  @@index([workspace_id, agent_name])
  @@index([user_id, created_at])
}