# ── SERVER ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_VERSION=v1

# ── DATABASE ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://nexus:nexus_pass@localhost:5432/nexus_social
# Prisma migrate dev: empty DB created once with TEMPLATE template0 (avoids template1 collation errors on postgres:alpine + Docker Desktop)
SHADOW_DATABASE_URL=postgresql://nexus:nexus_pass@localhost:5432/prisma_migrate_shadow

# ── REDIS (Bull queues) ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ─────────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_min_32_characters_use_openssl_rand_base64_48
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ── ENCRYPTION (OAuth tokens at rest) ───────────────────────────────────────────
# Generate: openssl rand -base64 48
ENCRYPTION_KEY=CHANGE_ME_min_32_characters_use_openssl_rand_base64_48

# ── STORAGE ─────────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local
# For AWS S3:
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=nexus-social-uploads
# For Cloudflare R2:
# S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com

# ── AI ──────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── STRIPE ──────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_PRICE_AGENCY=price_...

# ── SOCIAL PLATFORMS (Original 8) ───────────────────────────────────────────────

# Meta — Instagram + Facebook (https://developers.facebook.com)
META_ACCESS_TOKEN=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Twitter / X (https://developer.twitter.com)
TWITTER_BEARER_TOKEN=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# LinkedIn (https://www.linkedin.com/developers)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# TikTok (https://developers.tiktok.com)
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# YouTube / Google (https://console.cloud.google.com)
YOUTUBE_API_KEY=

# Pinterest (https://developers.pinterest.com)
PINTEREST_ACCESS_TOKEN=

# Twitch (https://dev.twitch.tv/console)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ── NEW PLATFORMS (8 new — from pages.config.js) ────────────────────────────────

# Bluesky AT Protocol (https://docs.bsky.app)
BLUESKY_CLIENT_ID=
BLUESKY_CLIENT_SECRET=

# Threads (Meta — https://developers.facebook.com/docs/threads)
THREADS_APP_ID=
THREADS_APP_SECRET=

# Truth Social (Mastodon-compatible)
TRUTHSOCIAL_CLIENT_ID=
TRUTHSOCIAL_CLIENT_SECRET=

# Rumble (partner API — https://rumble.com)
RUMBLE_API_KEY=

# Kick (https://kick.com)
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

# Spotify (https://developer.spotify.com)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Google Business Profile (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_API_KEY=

# Shopify (https://shopify.dev)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# ── OAUTH CALLBACK BASE URL ──────────────────────────────────────────────────────
OAUTH_CALLBACK_BASE_URL=http://localhost:4000

# ── EMAIL SMTP ───────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@nexussocial.app

# ─── OAUTH: ALL 16 PLATFORMS ─────────────────────────────────────────────────
# Get credentials from each platform's developer console

# Meta / Instagram / Threads
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
THREADS_CLIENT_ID=          # defaults to INSTAGRAM_CLIENT_ID
THREADS_CLIENT_SECRET=      # defaults to INSTAGRAM_CLIENT_SECRET

# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Twitter / X
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Google (YouTube + Google Business Profile)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Pinterest
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# Twitch
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Shopify
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Truth Social (Mastodon compatible)
TRUTH_SOCIAL_CLIENT_ID=
TRUTH_SOCIAL_CLIENT_SECRET=

# Kick + Rumble: API key only (no OAuth)
# KICK_API_KEY=
# RUMBLE_API_KEY=

# ─── STORAGE: S3 / CLOUDFLARE R2 ─────────────────────────────────────────────
# Cloudflare R2 (recommended — cheaper than S3)
R2_ACCOUNT_ID=              # Your Cloudflare account ID
R2_ACCESS_KEY_ID=           # R2 API token access key
R2_SECRET_ACCESS_KEY=       # R2 API token secret
R2_BUCKET=nexus-social      # Your R2 bucket name
R2_PUBLIC_URL=              # Optional: custom domain for public files

# AWS S3 (alternative)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=nexus-social

# ─── EMAIL: SMTP / SENDGRID ───────────────────────────────────────────────────
# SendGrid (recommended)
SENDGRID_API_KEY=           # sk- prefixed SendGrid API key

# Custom SMTP (alternative)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
EMAIL_FROM=noreply@nexussocial.io

# ─── APP URLS ─────────────────────────────────────────────────────────────────
APP_URL=http://localhost:4000    # Backend URL (used in OAuth redirect URIs)
FRONTEND_URL=http://localhost:3000  # Frontend URL (OAuth success/error redirect)

# ─── FRONTEND API URL ─────────────────────────────────────────────────────────
# Used by base44Client.js to connect to this backend.
# In your frontend project's .env:
VITE_API_URL=http://localhost:4000/v1

# Production:
# VITE_API_URL=https://api.yourdomain.com/v1

# ─── PLATFORM OAUTH CREDENTIALS ──────────────────────────────────────────────
# Each platform requires an app/developer account. All are optional —
# only set the ones you want to support.

# Instagram (Graph API)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Twitter / X
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# YouTube + Google Business (same OAuth app)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Pinterest
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# Twitch
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Threads (uses Instagram credentials)
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Shopify Partner
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Truth Social
TRUTH_SOCIAL_CLIENT_ID=
TRUTH_SOCIAL_CLIENT_SECRET=

# Kick.com (beta developer program)
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

# Rumble (partner program)
RUMBLE_CLIENT_ID=
RUMBLE_CLIENT_SECRET=

# Bluesky / ATP (app password, not OAuth)
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=
