# ─── Nexus Social Frontend Environment ───────────────────────────────────────
# Copy to .env for development, .env.production for production builds.

# Backend API URL (required)
# Development:
VITE_API_URL=http://localhost:4000/v1
# Production:
# VITE_API_URL=https://api.yourdomain.com/v1

# Optional: app name for browser tab title
VITE_APP_NAME=Nexus Social
